{
  "name": "flipwall-watchface",
  "author": "MakeAwesomeHappen",
  "version": "1.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "scripts": {
    "build": "pebble clean && pebble build",
    "emulator": "npm run build && pebble install --emulator ",
    "phone": "npm run build && pebble install --phone",
    "config": "pebble emu-app-config --emulator",
    "logs": "pebble logs"
  },
  "pebble": {
    "displayName": "flipwall-watchface",
    "uuid": "8d530349-f7cc-4337-b077-e2af3337783e",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "messageKeys": [
      "YearTop",
      "BlockTopLeft",
      "BlockTopRight",
      "BlockBottomLeft",
      "BlockBottomRight",
      "FaceColor",
      "PanelColor",
      "WeekendColor",
      "TextColor",
      "ShowSeconds"
    ],
